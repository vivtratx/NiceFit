<%- include('header') %>

<% if (user && user.role === 'admin') { %>
<div class="admin-page">
  <h2>Admin</h2>

 <!-- Orders Table -->
<h3>Orders</h3>
  <!-- Filters & Sorting -->
  <form method="GET" action="/admin">
    <label>Status:
      <select name="statusFilter">
        <option value="all"        <%= (!query.statusFilter || query.statusFilter === 'all')        ? 'selected' : '' %>>All</option>
        <option value="placed"     <%= query.statusFilter === 'placed'       ? 'selected' : '' %>>Placed</option>
        <option value="processing" <%= query.statusFilter === 'processing'   ? 'selected' : '' %>>Processing</option>
        <option value="shipped"    <%= query.statusFilter === 'shipped'      ? 'selected' : '' %>>Shipped</option>
        <option value="delivered"  <%= query.statusFilter === 'delivered'    ? 'selected' : '' %>>Delivered</option>
        <option value="cancelled"  <%= query.statusFilter === 'cancelled'    ? 'selected' : '' %>>Cancelled</option>
      </select>
    </label>

    <label>Sort by:
      <select name="sortBy">
        <option value="date"     <%= (!query.sortBy || query.sortBy === 'date')     ? 'selected' : '' %>>Date</option>
        <option value="customer" <%= query.sortBy === 'customer' ? 'selected' : '' %>>Customer</option>
        <option value="total"    <%= query.sortBy === 'total'    ? 'selected' : '' %>>Total</option>
      </select>
    </label>

    <label>Direction:
      <select name="sortDir">
        <option value="DESC" <%= (!query.sortDir || query.sortDir === 'DESC') ? 'selected' : '' %>>Descending</option>
        <option value="ASC"  <%= query.sortDir === 'ASC' ? 'selected' : '' %>>Ascending</option>
      </select>
    </label>

    <button type="submit">Apply</button>
    <a href="/admin">Reset</a>
  </form>

  <% if (orders.length === 0) { %>
    <p>No orders found.</p>
  <% } else { %>
    <table>
      <tr>
        <th>Order ID</th>
        <th>Customer</th>
        <th>Date</th>
        <th>Status</th>
        <th>Total</th>
      </tr>
      <% orders.forEach(o => { %>
      <tr>
        <td>#<%= o.orderID %></td>
        <td><%= o.firstName %> <%= o.lastName %></td>
        <td><%= new Date(o.orderDate).toLocaleDateString() %></td>
        <td><%= o.status %></td>
        <td>$<%= Number(o.orderTotal).toFixed(2) %></td>
      </tr>
      <% }) %>
    </table>
  <% } %>

  <!-- Inventory -->
<h3>Inventory</h3>
<p>Add a new SKU (one row per product + color + size).</p>

<form action="/admin/inventory/create" method="POST" class="admin-inventory-create">
  <div class="admin-form-grid">
    <label>Product name <input type="text" name="product" required maxlength="150" placeholder="e.g. Ribbed Crop Tank" /></label>
    <label>Category <input type="text" name="category" maxlength="100" placeholder="Tops" /></label>
    <label>Gender
      <select name="gender" required>
        <% genders.forEach(function (g) { %>
          <option value="<%= g %>" <%= g === 'Unisex' ? 'selected' : '' %>><%= g %></option>
        <% }); %>
      </select>
    </label>
    <label>Color <input type="text" name="color" maxlength="50" placeholder="Black" /></label>
    <label>Size <input type="text" name="size" maxlength="10" placeholder="M" /></label>
    <label>Price <input type="number" name="price" step="0.01" min="0" required /></label>
    <label>Quantity <input type="number" name="quantity" min="0" step="1" value="0" required /></label>
    <label>Image URL <input type="text" name="imageURL" maxlength="500" placeholder="/images/your-file.jpg" /></label>
  </div>
  <label class="admin-checkbox"><input type="checkbox" name="onSale" value="1" /> On sale</label>
  <div class="admin-full-width-row">
    <label>Sale price <input type="number" name="salePrice" step="0.01" min="0" placeholder="If on sale" /></label>
    <label class="admin-full-width">Description<br />
      <textarea name="description" rows="2" maxlength="2000" placeholder="Optional"></textarea>
    </label>
  </div>
  <button type="submit">Create SKU</button>
</form>

<% if (!inventory || inventory.length === 0) { %>
  <p>No inventory rows.</p>
<% } else { %>
  <details class="inventory-dropdown">
    <summary>Show inventory (<%= inventory.length %> items)</summary>
    <table class="admin-inventory-table">
      <tr>
        <th>ID</th>
        <th>Product</th>
        <th>Category</th>
        <th>Color</th>
        <th>Size</th>
        <th>Price</th>
        <th>Qty</th>
        <th>Sale</th>
        <th></th>
      </tr>
      <% inventory.forEach(inv => { %>
      <tr>
        <td><%= inv.ProductID %></td>
        <td><%= inv.product %></td>
        <td><%= inv.category %></td>
        <td><%= inv.color %></td>
        <td><%= inv.size %></td>
        <td><%= inv.price %></td>
        <td><%= inv.quantity %></td>
        <td><%= inv.onSale ? (inv.salePrice != null ? '$' + Number(inv.salePrice).toFixed(2) : 'Yes') : '—' %></td>
        <td>
          <a href="/admin/inventory/item/<%= inv.ProductID %>/edit">Edit</a>
          <form action="/admin/inventory/item/<%= inv.ProductID %>?_method=DELETE" method="POST">
            <button type="submit">Delete</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </table>
  </details>
<% } %>

  <!-- Discount Codes -->
  <h3>Discount Codes</h3>

  <form action="/admin/discounts" method="POST">
    <input type="text"   name="code"          placeholder="Code (e.g. SAVE10)" required />
    <select name="discountType">
      <option value="percent">Percent</option>
      <option value="flat">Flat</option>
    </select>
    <input type="number" name="discountValue"  placeholder="Value" step="0.01" required />
    <input type="number" name="usageLimit"     placeholder="Usage limit (optional)" />
    <input type="date"   name="expiresAt"      placeholder="Expiry (optional)" />
    <button type="submit">Create Code</button>
  </form>

  <% if (discounts.length === 0) { %>
    <p>No discount codes.</p>
  <% } else { %>
    <table>
      <tr>
        <th>Code</th>
        <th>Type</th>
        <th>Value</th>
        <th>Usage</th>
        <th>Expires</th>
        <th>Active</th>
        <th>Action</th>
      </tr>
      <% discounts.forEach(d => { %>
      <tr>
        <td><%= d.code %></td>
        <td><%= d.discountType %></td>
        <td><%= d.discountType === 'percent' ? d.discountValue + '%' : '$' + d.discountValue %></td>
        <td><%= d.usageCount %><%= d.usageLimit ? ' / ' + d.usageLimit : '' %></td>
        <td><%= d.expiresAt ? new Date(d.expiresAt).toLocaleDateString() : 'Never' %></td>
        <td><%= d.isActive ? 'Yes' : 'No' %></td>
        <td>
          <form action="/admin/discounts/<%= d.discountID %>?_method=DELETE" method="POST">
            <button type="submit">Delete</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </table>
  <% } %>

  <!-- Users -->
  <h3>Users</h3>
  <% if (users.length === 0) { %>
    <p>No users found.</p>
  <% } else { %>
    <table>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Email</th>
        <th>Role</th>
        <th>Change Role</th>
        <th>Delete</th>
      </tr>
      <% users.forEach(u => { %>
      <tr>
        <td><%= u.UserID %></td>
        <td><%= u.firstName %> <%= u.lastName %></td>
        <td><%= u.email %></td>
        <td><%= u.role %></td>
        <td>
          <% if (u.UserID !== user.UserID) { %>
            <form action="/admin/users/<%= u.UserID %>/role" method="POST">
              <select name="role">
                <option value="customer" <%= u.role === 'customer' ? 'selected' : '' %>>Customer</option>
                <option value="admin"    <%= u.role === 'admin'    ? 'selected' : '' %>>Admin</option>
              </select>
              <button type="submit">Update</button>
            </form>
          <% } else { %>
            <em>(you)</em>
          <% } %>
        </td>
        <td>
          <% if (u.UserID !== user.UserID) { %>
            <form action="/admin/users/<%= u.UserID %>?_method=DELETE" method="POST">
              <button type="submit">Delete</button>
            </form>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </table>
  <% } %>

</div>
<% } else { %>
  <p>Access denied.</p>
<% } %>

<%- include('footer') %>